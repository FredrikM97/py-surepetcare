{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install Dev Requirements",
      "type": "shell",
      "command": "uv sync --all-extras --dev",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Pytest",
      "type": "shell",
      "command": "uv run pytest tests",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Update Syrupy Snapshots",
      "type": "shell",
      "command": "uv run pytest --snapshot-update tests",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint (Ruff)",
      "type": "shell",
      "command": "uv run ruff check .",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Format (Ruff)",
      "type": "shell",
      "command": "uv run ruff format .",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Lint (Pylint)",
      "type": "shell",
      "command": "uv run pylint surepcio surepccli tests",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Pre-commit Autoupdate",
      "type": "shell",
      "command": "uv run pre-commit autoupdate",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Pre-commit format",
      "type": "shell",
      "command": "uv run pre-commit run --all-files",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Update uv Lock",
      "type": "shell",
      "command": "uv lock",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
}