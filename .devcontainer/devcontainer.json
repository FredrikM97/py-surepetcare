{
  "name": "Python Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "GitHub.copilot"
      ]
    }
  },
  "mounts": [
    "type=bind,source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh"
  ],
  "postCreateCommand": "pip install uv && uv sync --all-extras --dev && uv run pre-commit install && ln -sf /workspaces/psp/.venv/bin/python /usr/local/bin/python",
  "postStartCommand": "git config --global --unset-all core.hooksPath || true" 
}